# LegalLens — Environment Variables
# Copy this file to backend/.env and fill in the values

# Required: Google Gemini API key
# Get yours free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Ollama fallback (used automatically when Gemini is unavailable)
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
# Recommended models: llama3.2, mistral, gemma3
# llama3.2 is the default — good balance of speed and quality for legal text
OLLAMA_MODEL=llama3.2
